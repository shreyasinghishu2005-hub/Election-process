# Copy to .env and fill in locally. Never commit real secrets.

# Optional Google Gemini key for richer assistant responses.
# Create one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional Google Cloud Text-to-Speech support for clearer elder-friendly audio.
# Based on the official Python client docs for google-cloud-texttospeech.
GOOGLE_TTS_ENABLED=true

# Optional service-account JSON for Google Cloud APIs.
# Keep this server-side only.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional comma-separated origins if you serve the frontend separately.
# ELECTION_GUIDE_CORS_ORIGINS=http://127.0.0.1:8001,http://localhost:8001
